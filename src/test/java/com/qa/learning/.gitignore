# Create .gitignore file
New-Item -Name ".gitignore" -ItemType File
```

Then open it in VS Code and paste this content:
```
# Maven build output - never commit this
target/

# Java compiled files
*.class
*.jar
*.war

# IDE files - IntelliJ
.idea/
*.iml
*.ipr
*.iws

# IDE files - VS Code
.vscode/
*.code-workspace

# Log files
*.log
logs/

# Test reports and results
allure-results/
allure-report/
reports/

# Playwright specific
test-results/
playwright-report/

# Screenshots
screenshots/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Environment and secrets - NEVER commit these
.env
*.properties.local
secrets/
credentials/

# Temporary files
*.tmp
*.bak
*.swp